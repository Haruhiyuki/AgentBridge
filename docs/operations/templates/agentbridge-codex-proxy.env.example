# Copy to ~/.config/agentbridge/codex-proxy.env with mode 0600.
# Replace placeholders before using the wrapper.

AGENTBRIDGE_API_URL=http://127.0.0.1:8000
AGENTBRIDGE_SESSION_ID=__SESSION_ID__

# Use either a managed device key or an API token.
AGENTBRIDGE_DEVICE_ID=codex-adapter
AGENTBRIDGE_DEVICE_KEY_FILE=__HOME__/.config/agentbridge/codex-adapter.key
# AGENTBRIDGE_API_TOKEN_FILE=__HOME__/.config/agentbridge/api.token

AGENTBRIDGE_ADAPTER_CLIENT_BIN=agentbridge-adapter-client
AGENTBRIDGE_CODEX_APP_SERVER_COMMAND="codex app-server"

AGENTBRIDGE_CODEX_PROXY_INJECT_RESPONSES=true
AGENTBRIDGE_CODEX_PROXY_FORWARD_INJECTED_REQUESTS=false
AGENTBRIDGE_CODEX_PROXY_RESTART_POLICY=on-failure
AGENTBRIDGE_CODEX_PROXY_MAX_RESTARTS=3
AGENTBRIDGE_CODEX_PROXY_RESTART_DELAY_SECONDS=1
AGENTBRIDGE_CODEX_PROXY_RESTART_MIN_UPTIME_SECONDS=5
AGENTBRIDGE_CODEX_PROXY_HEALTH_INTERVAL_SECONDS=30
AGENTBRIDGE_CODEX_PROXY_HEALTH_OUTPUT_FILE=__HOME__/.local/state/agentbridge/codex-proxy-health.jsonl
AGENTBRIDGE_CODEX_PROXY_BRIDGE_OUTPUT_FILE=__HOME__/.local/state/agentbridge/codex-proxy-responses.jsonl
