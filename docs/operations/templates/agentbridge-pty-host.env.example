# Copy to ~/.config/agentbridge/pty-host.env with mode 0600.
# Replace placeholders before starting the service.

AGENTBRIDGE_TERMINAL_PTY_HOST_SOCKET=__XDG_RUNTIME_DIR__/agentbridge/pty-host.sock
AGENTBRIDGE_TERMINAL_PTY_HOST_TOKEN_FILE=__HOME__/.config/agentbridge/pty-host.token
AGENTBRIDGE_TERMINAL_PTY_HOST_STATE_PATH=__HOME__/.local/state/agentbridge/pty-host-state.json
AGENTBRIDGE_TERMINAL_PTY_OUTPUT_LIMIT_CHARS=1000000
